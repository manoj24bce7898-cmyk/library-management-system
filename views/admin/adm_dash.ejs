
<div class="HEADER1">
  <h2>Admin Dashboard</h2>
  <p id="typing-heading1"></p>
</div>

<hr>

<!-- ================= ENGLISH BOOKS ================= -->

<h2 id="typing-heading"></h2>
<div class="middle">
<div class="book-grid">
  <% if(books && books.length > 0) { %>
    <% books.forEach(book => { %>
      <div class="book-card">

        <div class="book-image">
          <img src="<%= book.bookImage %>" alt="<%= book.title %>">
        </div>

        <div class="book-content">
          <h3><%= book.title %></h3>
          <p>Author: <%= book.author %></p>
          <p>Year: <%= book.year %> | Sem: <%= book.semester %></p>
          <p>Subject: <%= book.subject %></p>
          <p><%= book.description %></p>

          <a href="/admin/books/<%= book._id %>/<%= email %>" class="book-btn">
            View Details
          </a>
          <a href="/removebook/<%=book._id%>/<%=email%>" class="book-btn" style="background-color: #e63946; margin-top: 10px;">
            Remove Book
            </a>
        </div>

      </div>
    <% }) %>
  <% } else { %>
    <p>No English books found.</p>
  <% } %>
</div>
</div>
<hr>

<!-- ================= MATHEMATICS BOOKS ================= -->

<h2>📘 Mathematics Books</h2>
<div class="middle">
<div class="book-grid">
  <% if(mathBooks && mathBooks.length > 0) { %>
    <% mathBooks.forEach(book => { %>
      <div class="book-card">

        <div class="book-image">
          <img src="<%= book.bookImage %>" alt="<%= book.title %>">
        </div>

        <div class="book-content">
          <h3><%= book.title %></h3>
          <p>Author: <%= book.author %></p>
          <p>Year: <%= book.year %> | Sem: <%= book.semester %></p>
          <p>Subject: <%= book.subject %></p>
          <p><%= book.description %></p>

          <a href="/books/<%= book._id %>/<%= email %>" class="book-btn">
            View Details
          </a>
        </div>

      </div>
    <% }) %>
  <% } else { %>
    <p>No Mathematics books found.</p>
  <% } %>
</div>

<hr>
</div>
<!-- ================= UPLOADED SYLLABUS PDFs ================= -->

<h2>📄 Uploaded Syllabus PDFs</h2>

<div class="pdf-grid">
  <% if(syllabi && syllabi.length > 0) { %>
    <% syllabi.forEach(pdf => { %>
      <div class="pdf-card">
        <h4><%= pdf.title %></h4>
        <a href="/uploads/<%= pdf.pdf %>" target="_blank">
          Open PDF
        </a>
      </div>
    <% }) %>
  <% } else { %>
    <p>No syllabus uploaded yet.</p>
  <% } %>
</div>

<style>

.middle{
    padding: 20px;
    background: linear-gradient(135deg, #f4f6fb, #e6e9f0);
    min-height: 100vh;
    position: relative;
    top: 20px;
    border-radius: 2rem;
    border: 2px solid #ccc;
}
.HEADER1 {
  width: 100%;
  height: 100%;
  border: 2px solid #ccc;
  text-align: center;
  margin-top: 20px;
  color: #1f2937; /* dark gray */
  border-radius: 2rem;
  background: linear-gradient(135deg, #f4f6fb, #e6e9f0);
  display: flex;
  flex-direction: column;
  padding: 20px;
}
.typing-heading {
  font-size: 28px;
  font-weight: 600;
  color: #1f2937; /* dark gray */
  letter-spacing: 0.5px;
  min-height: 40px; /* prevents layout jump */
  position: relative;
  padding: 10px;
  left: 10px;
  margin-top: 15px;
}

.book-recommendations {
  margin-top: 30px;
  width: 100%;
  height: 100%;
  border: 2px solid #ccc;
  border-radius: 2rem;
  background: linear-gradient(135deg, #f4f6fb, #e6e9f0);
  display: flex;
  flex-direction: column;
  padding: auto;
}
    /* GRID LAYOUT */
.book-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 35px;
  padding: 40px;
}

/* CARD */
.book-card {
  background: linear-gradient(180deg, #1e1e2f, #26263d);
  border-radius: 18px;
  overflow: hidden;
  box-shadow: 0 15px 35px rgba(0,0,0,0.45);
  transition: all 0.4s ease;
  transform-style: preserve-3d;
  position: relative;
}

/* HOVER EFFECT */
.book-card:hover {
  transform: translateY(-12px) scale(1.03);
  box-shadow: 0 25px 55px rgba(0,0,0,0.7);
}

/* IMAGE */
.book-image {
  height: 260px;
  overflow: hidden;
}

.book-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease;
}

.book-card:hover img {
  transform: scale(1.12);
}

/* CONTENT */
.book-content {
  padding: 20px;
  color: #eaeaea;
}

/* TITLE */
.book-title {
  font-size: 18px;
  font-weight: 600;
  margin-bottom: 6px;
}

/* AUTHOR */
.book-author {
  font-size: 14px;
  color: #b5b5b5;
  margin-bottom: 12px;
}

/* META INFO */
.book-meta {
  display: flex;
  gap: 10px;
  font-size: 12px;
  margin-bottom: 12px;
}

.book-meta span {
  background: rgba(255,255,255,0.08);
  padding: 4px 8px;
  border-radius: 8px;
}

/* DESCRIPTION */
.book-desc {
  font-size: 13px;
  line-height: 1.6;
  color: #cfcfcf;
  margin-bottom: 16px;
}

/* BUTTON */
.book-btn {
  display: inline-block;
  text-decoration: none;
  padding: 10px 18px;
  border-radius: 25px;
  background: linear-gradient(135deg, #ffb703, #fb8500);
  color: #111;
  font-size: 13px;
  font-weight: 600;
  transition: all 0.35s ease;
}

.book-btn:hover {
  background: linear-gradient(135deg, #ffd166, #f77f00);
  transform: translateY(-2px);
}

</style>

<script>
  const text = "📚 English Books ";
  const heading = document.getElementById("typing-heading");
  const text1 = "Welcome Admin: <%= email %> ";
  const heading1 = document.getElementById("typing-heading1");
  const heading2 = document.getElementById("typing-heading2");
  
  let index = 0;

  function typeText() {
    if (index < text.length) {
      heading.textContent += text.charAt(index);
      index++;
      setTimeout(typeText, 50); // typing speed
    } else {
      setTimeout(() => {
        heading.textContent = "";
        index = 0;
        setTimeout(typeText, 600); // delay before restart
      }, 1200); // pause after full text
    }
  }
  let index1 = 0;
  function typeText1() {
    if (index1 < text1.length) {
      heading1.textContent += text1.charAt(index1);
      index1++;
      setTimeout(typeText1, 50); // typing speed
    } else {
      setTimeout(() => {
        heading1.textContent = "";
        index1 = 0;
        setTimeout(typeText1, 600); // delay before restart
      }, 1200); // pause after full text
    }
  }
  let index2 = 0;
  function typeText2() {
    if (index2 < text2.length) {
      heading2.textContent += text2.charAt(index2);
      index2++;
      setTimeout(typeText2, 50); // typing speed
    } else {
      setTimeout(() => {
        heading2.textContent = "";
        index2 = 0;
        setTimeout(typeText2, 600); // delay before restart
      }, 1200); // pause after full text
    }
  }
  setTimeout(typeText2, 600); 
  setTimeout(typeText1, 600);
  // Start typing after 0.6s when page loads
  setTimeout(typeText, 600);
</script>

