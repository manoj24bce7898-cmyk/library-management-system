<h1 class="search-title">Search Results</h1>

<div class="book-grid">

<% books.forEach(book => { %>

<div class="book-card">

<div class="book-image">
<img src="<%= book.bookImage %>" alt="<%= book.title %>">
</div>

<div class="book-content">

<h3 class="book-title"><%= book.title %></h3>

<p class="book-author">by <%= book.author %></p>

<div class="book-meta">
<span>Year <%= book.year %></span>
<span>Sem <%= book.semester %></span>
<span><%= book.subject %></span>
</div>

<p class="book-desc">
<%= book.description %>
</p>

<a href="/books/<%= book._id %>/<%= email %>" class="book-btn">
View Details
</a>

</div>

</div>

<% }) %>

</div>


<style>

/* TITLE */

.search-title{

margin-top:20px;

margin-bottom:20px;

font-size:28px;

font-weight:600;

color:#1f2937;

padding-left:10px;

}


/* GRID */

.book-grid{

display:grid;

grid-template-columns:repeat(auto-fit,minmax(250px,1fr));

gap:30px;

padding:30px;

border:2px solid #ccc;

border-radius:2rem;

background:linear-gradient(135deg,#f4f6fb,#e6e9f0);

}


/* CARD */

.book-card{

background:linear-gradient(180deg,#1e1e2f,#26263d);

border-radius:18px;

overflow:hidden;

box-shadow:0 15px 35px rgba(0,0,0,0.45);

transition:all 0.35s ease;

}

.book-card:hover{

transform:translateY(-10px);

box-shadow:0 25px 55px rgba(0,0,0,0.7);

}


/* IMAGE */

.book-image{

height:240px;

overflow:hidden;

}

.book-image img{

width:100%;

height:100%;

object-fit:cover;

transition:transform 0.5s ease;

}

.book-card:hover img{

transform:scale(1.1);

}


/* CONTENT */

.book-content{

padding:18px;

color:#eaeaea;

}


/* TITLE */

.book-title{

font-size:18px;

font-weight:600;

margin-bottom:6px;

}


/* AUTHOR */

.book-author{

font-size:14px;

color:#b5b5b5;

margin-bottom:10px;

}


/* META */

.book-meta{

display:flex;

flex-wrap:wrap;

gap:8px;

font-size:12px;

margin-bottom:10px;

}

.book-meta span{

background:rgba(255,255,255,0.08);

padding:4px 8px;

border-radius:8px;

}


/* DESCRIPTION */

.book-desc{

font-size:13px;

line-height:1.6;

color:#cfcfcf;

margin-bottom:14px;

}


/* BUTTON */

.book-btn{

display:inline-block;

text-decoration:none;

padding:10px 18px;

border-radius:25px;

background:linear-gradient(135deg,#ffb703,#fb8500);

color:#111;

font-size:13px;

font-weight:600;

transition:all 0.3s ease;

}

.book-btn:hover{

background:linear-gradient(135deg,#ffd166,#f77f00);

transform:translateY(-2px);

}


/* TABLET */

@media(max-width:768px){

.search-title{

font-size:24px;

}

.book-grid{

gap:22px;

padding:20px;

}

}


/* MOBILE */

@media(max-width:480px){

.search-title{

font-size:20px;

text-align:center;

}

.book-grid{

grid-template-columns:1fr;

gap:18px;

padding:15px;

}

.book-image{

height:200px;

}

}

</style>