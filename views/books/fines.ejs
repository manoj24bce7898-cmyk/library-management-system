
<!-- Razorpay Checkout -->
<div class="fine-page">

<div class="fine-header">
<h2>Overdue Books & Fines</h2>
</div>

<% if (overdueBooks.length === 0) { %>

<div class="no-fine">
No fines pending 🎉
</div>

<% } else { %>

<div class="table-wrapper">

<table class="fine-table">

<thead>

<tr>
<th>Title</th>
<th>Author</th>
<th>Due Date</th>
<th>Fine</th>
<th>Action</th>
</tr>

</thead>

<tbody>

<% overdueBooks.forEach(book => { %>

<tr>

<td><%= book.title %></td>

<td><%= book.author %></td>

<td>
<%= new Date(book.duedate).toLocaleDateString() %>
</td>

<td class="fine-amount">
₹<%= book.fineAmount %>
</td>

<td>

<button 
class="pay-btn">
Pay Now 
</button>
</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

<% } %>

</div>


<style>

/* PAGE */

.fine-page{

max-width:1100px;

margin:auto;

padding:40px 20px;

}


/* HEADER */

.fine-header{

padding:25px;

border-radius:20px;

text-align:center;

background:linear-gradient(135deg,#f4f6fb,#e6e9f0);

border:2px solid #ccc;

margin-bottom:30px;

}

.fine-header h2{

font-size:28px;

color:#1f2937;

}


/* NO FINE MESSAGE */

.no-fine{

padding:25px;

background:#d1fae5;

color:#065f46;

border-radius:14px;

text-align:center;

font-weight:600;

}


/* TABLE WRAPPER */

.table-wrapper{

overflow-x:auto;

}


/* TABLE */

.fine-table{

width:100%;

border-collapse:collapse;

background:white;

border-radius:16px;

overflow:hidden;

box-shadow:0 10px 25px rgba(0,0,0,0.15);

}

.fine-table thead{

background:#1e1e2f;

color:white;

}

.fine-table th,
.fine-table td{

padding:14px 16px;

text-align:left;

border-bottom:1px solid #e5e7eb;

}


/* FINE AMOUNT */

.fine-amount{

font-weight:600;

color:#ef4444;

}


/* PAY BUTTON */

.pay-btn{

padding:8px 18px;

border:none;

border-radius:25px;

background:linear-gradient(135deg,#ffb703,#fb8500);

color:#111;

font-weight:600;

cursor:pointer;

transition:all 0.3s;

}

.pay-btn:hover{

transform:translateY(-2px);

background:linear-gradient(135deg,#ffd166,#f77f00);

}


/* TABLET */

@media(max-width:768px){

.fine-header h2{

font-size:24px;

}

.fine-table th,
.fine-table td{

padding:12px;

font-size:14px;

}

}


/* MOBILE */

@media(max-width:480px){

.fine-page{

padding:25px 12px;

}

.fine-header h2{

font-size:20px;

}

.pay-btn{

width:100%;

}

}

</style>



<script>

const RAZORPAY_KEY_ID = "rzp_test_AbCdEfGh12345";


async function payFine(bookId,fineAmount){

try{

const res = await fetch(`/create-payment/${bookId}`,{
method:"POST"
});

const data = await res.json();


const options={

key:RAZORPAY_KEY_ID,

amount:data.amount,

currency:"INR",

name:"Library Management System",

description:"Overdue Book Fine",

order_id:data.orderId,


handler:async function(response){

await fetch(`/payment-success/${bookId}`,{
method:"POST"
});

alert("Payment Successful ✅");

window.location.reload();

},


prefill:{
name:"<%= profile.firstName %>",
email:"<%= profile.email %>"
},

theme:{
color:"#0d6efd"
}

};


const rzp = new Razorpay(options);

rzp.open();

}

catch(error){

console.error("Payment error:",error);

alert("Payment failed. Try again.");

}

}

</script>