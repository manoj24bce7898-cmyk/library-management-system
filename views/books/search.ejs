<div class="header">
    <form action="/search/<%= email %>/submit" method="post">
    <div class="col-md-6">
        <label for="inputsub" class="form-label">Enter subject:</label>
        <select id="inputYear" class="form-select" name="sub" >
            <option selected>Choose...</option>
            <option>English</option>
            <option>Mathematics</option>
            <option>Chemistry</option>
            <option>Physics</option>
        </select>
    </div>
    <div class="col-md-6">
        <label for="inputsub" class="form-label">Enter year:</label>
        <select id="inputYear" class="form-select" name="year">
            <option selected>Choose...</option>
            <option>1</option>
            <option>2</option>
            <option>3</option>
            <option>4</option>
        </select>
    </div>
    <button type="submit" class="btn btn-primary" style="position: relative; top: 10px; left: 5px;">Search</button>
    </form>
</div>


<style>
.header {
    width: 100%;
    height: 100%;
    margin-top: 20px;
    margin-bottom: 30px;
    padding: 20px;
    background: linear-gradient(135deg, #1e1e2f, #2b2b40);
    border-radius: 15px;
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.45);
    color: #ffffff;
    gap: 20px;
}

.form-label {
    color: #eaeaea;
}

.form-select {
    background: #2b2b40;
    color: #eaeaea;
    border: 2px solid #ffb703;
    border-radius: 8px;
    padding: 10px;
}

.form-select:hover {
    background: #3a3a55;
}
/* HOVER EFFECT */
.header:hover {
    transform: translateY(-10px) scale(1.01);
    box-shadow: 0 35px 90px rgba(0, 0, 0, 0.7);
}
</style>
