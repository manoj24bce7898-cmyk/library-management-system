<style>

/* NAVBAR */

.navbar{
height:70px;
padding:0 40px;
background:rgba(30,30,47,0.9);
backdrop-filter:blur(8px);
display:flex;
align-items:center;
justify-content:space-between;
position:relative;
z-index:1000;
}


/* LEFT SECTION */

.nav-left{
display:flex;
align-items:center;
gap:14px;
}


/* LOGO */

.logo-icon{
font-size:30px;
color:#ffb703;
transition:transform .3s,color .3s;
}

.navbar-brand:hover .logo-icon{
transform:rotate(-15deg) scale(1.15);
color:#ffd166;
}


/* TITLE */

.library-text{
font-family:"Plus Jakarta Sans",sans-serif;
font-size:20px;
font-weight:600;
color:#f1f1f1;
letter-spacing:1px;
}


/* NAV LINKS */

.nav-links{
list-style:none;
display:flex;
gap:35px;
align-items:center;
}


/* LINK STYLE */

.nav-links a{
text-decoration:none;
color:#dcdcdc;
font-size:16px;
position:relative;
transition:color .3s;
}


/* UNDERLINE ANIMATION */

.nav-links a::after{
content:"";
position:absolute;
width:0%;
height:2px;
background:#ffb703;
left:0;
bottom:-6px;
transition:width .3s;
}

.nav-links a:hover::after{
width:100%;
}

.nav-links a:hover{
color:white;
}


/* PROFILE BUTTON */

.profile-btn{
padding:8px 18px;
background:linear-gradient(135deg,#ffb703,#fb8500);
color:#1e1e2f;
border-radius:20px;
font-weight:600;
display:flex;
align-items:center;
gap:8px;
transition:transform .3s,box-shadow .3s;
}

.profile-btn:hover{
transform:scale(1.08);
box-shadow:0 0 18px rgba(255,183,3,0.7);
}


/* HAMBURGER */

.menu-toggle{
display:none;
font-size:24px;
color:white;
cursor:pointer;
}


/* MOBILE RESPONSIVE */

@media(max-width:900px){

.menu-toggle{
display:block;
}

.nav-links{
position:absolute;
top:70px;
left:0;
width:100%;
background:#1e1e2f;

flex-direction:column;
align-items:center;

gap:25px;
padding:25px 0;

display:none;
}

.nav-links.active{
display:flex;
}

}

</style>


<script>

const toggle = document.getElementById("menu-toggle");
const navLinks = document.getElementById("nav-links");

toggle.addEventListener("click", () => {
navLinks.classList.toggle("active");
});

</script>