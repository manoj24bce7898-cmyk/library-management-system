<div class="profile-page">

<!-- PROFILE HEADER -->

<div class="profile-card">

<div class="profile-left">

<div class="profile-photo">
<img src="/images/profile-default.png" alt="Profile Photo">
</div>

</div>

<div class="profile-right">

<h2><%= profile.firstName %> <%= profile.lastName %></h2>

<p class="profile-email"><%= profile.email %></p>

<div class="profile-badges">
<span><%= profile.course %></span>
<span>Semester <%= profile.semester %></span>
<span>Year <%= profile.year %></span>
</div>

</div>

</div>


<!-- DETAILS SECTION -->

<div class="details-card">

<h3>Profile Details</h3>

<div class="details-grid">

<div class="detail-item">
<span>Registration Number</span>
<p><%= profile.regNumber %></p>
</div>

<div class="detail-item">
<span>Course</span>
<p><%= profile.course %></p>
</div>

<div class="detail-item">
<span>Semester</span>
<p><%= profile.semester %></p>
</div>

<div class="detail-item">
<span>Year</span>
<p><%= profile.year %></p>
</div>

<div class="detail-item">
<span>Email</span>
<p><%= profile.email %></p>
</div>

</div>


<!-- BUTTONS -->

<div class="profile-actions">

<a href="/student/profile/edit/<%= profile.email %>" class="edit-btn">
<i class="fa-solid fa-pen"></i> Edit Details
</a>

<a href="/" class="logout-btn">
Logout
</a>

</div>

</div>

</div>


<style>

/* PAGE CONTAINER */

.profile-page{
max-width:1100px;
margin:auto;
padding:40px 20px 80px;
}


/* PROFILE HEADER */

.profile-card{

background:linear-gradient(135deg,#1e1e2f,#2b2b40);

border-radius:20px;

padding:30px;

display:flex;

gap:30px;

align-items:center;

color:white;

box-shadow:0 20px 50px rgba(0,0,0,0.4);

transition:transform 0.4s,box-shadow 0.4s;

}

.profile-card:hover{
transform:translateY(-6px);
box-shadow:0 30px 70px rgba(0,0,0,0.6);
}


/* PROFILE PHOTO */

.profile-photo{

width:130px;
height:130px;

border-radius:50%;

overflow:hidden;

border:4px solid #ffb703;

}

.profile-photo img{

width:100%;
height:100%;

object-fit:cover;

}


/* PROFILE TEXT */

.profile-right h2{

font-size:26px;

margin-bottom:6px;

}

.profile-email{

color:#dcdcdc;

font-size:14px;

margin-bottom:14px;

}


/* BADGES */

.profile-badges{

display:flex;

gap:10px;

flex-wrap:wrap;

}

.profile-badges span{

background:rgba(255,255,255,0.15);

padding:6px 14px;

border-radius:20px;

font-size:13px;

transition:background 0.3s;

}

.profile-badges span:hover{

background:#ffb703;

color:#1e1e2f;

}


/* DETAILS CARD */

.details-card{

background:rgba(30,30,47,0.9);

margin-top:35px;

padding:30px;

border-radius:18px;

color:white;

box-shadow:0 15px 40px rgba(0,0,0,0.4);

}

.details-card h3{

margin-bottom:25px;

color:#ffb703;

letter-spacing:1px;

}


/* DETAILS GRID */

.details-grid{

display:grid;

grid-template-columns:repeat(auto-fit,minmax(220px,1fr));

gap:20px;

}

.detail-item{

background:rgba(255,255,255,0.08);

padding:18px;

border-radius:14px;

transition:transform 0.3s,background 0.3s;

}

.detail-item:hover{

transform:translateY(-6px);

background:rgba(255,183,3,0.15);

}

.detail-item span{

font-size:12px;

color:#bfbfbf;

}

.detail-item p{

font-size:16px;

margin-top:6px;

}


/* BUTTON SECTION */

.profile-actions{

display:flex;

gap:15px;

margin-top:30px;

flex-wrap:wrap;

}


/* EDIT BUTTON */

.edit-btn{

display:inline-flex;

align-items:center;

gap:8px;

padding:12px 26px;

background:linear-gradient(135deg,#ffb703,#fb8500);

color:#1e1e2f;

font-weight:600;

border-radius:30px;

text-decoration:none;

box-shadow:0 10px 25px rgba(255,183,3,0.35);

transition:all 0.3s ease;

}

.edit-btn:hover{

transform:translateY(-3px);

box-shadow:0 18px 40px rgba(255,183,3,0.6);

}


/* LOGOUT BUTTON */

.logout-btn{

padding:12px 24px;

background:#ef4444;

color:white;

border-radius:30px;

text-decoration:none;

font-weight:600;

transition:background 0.3s;

}

.logout-btn:hover{

background:#dc2626;

}


/* TABLET */

@media(max-width:768px){

.profile-card{

flex-direction:column;

text-align:center;

}

.profile-photo{

width:110px;
height:110px;

}

.profile-right h2{

font-size:22px;

}

}


/* MOBILE */

@media(max-width:480px){

.profile-page{

padding:30px 15px 70px;

}

.profile-photo{

width:90px;
height:90px;

}

.profile-right h2{

font-size:20px;

}

.profile-actions{

flex-direction:column;

}

.edit-btn,
.logout-btn{

width:100%;
text-align:center;
justify-content:center;

}

}

</style>