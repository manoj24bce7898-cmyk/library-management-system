    background:#ffffff;
    color:#1e1e2f;

    transition:box-shadow 0.3s ease, transform 0.3s ease;
}

.input-group input:focus{
    transform:scale(1.02);
    box-shadow:0 0 0 3px rgba(255,183,3,0.45);
}

