<style>

/* PAGE takes full available space under navbar */
.ai-page{

height:calc(100vh - 80px);
display:flex;
flex-direction:column;

}


/* Main wrapper */
.ai-wrapper{

flex:1;
display:flex;
border:1px solid #ddd;
border-radius:10px;
overflow:hidden;
background:white;

}


/* Sidebar */
.ai-sidebar{

width:260px;
background:#f4f4f4;
display:flex;
flex-direction:column;
border-right:1px solid #ddd;

}

.ai-title{

padding:15px;
background:#212529;
color:white;
font-weight:600;

}

.ai-newchat{

margin:10px;
padding:10px;
background:#343a40;
color:white;
border:none;
border-radius:6px;
cursor:pointer;

}

.ai-history{

flex:1;
overflow-y:auto;
padding:10px;

}


/* Main chat */
.ai-main{

flex:1;
display:flex;
flex-direction:column;

}


.ai-chat{

flex:1;
overflow-y:auto;
padding:20px;
background:#f8f9fa;
display:flex;
flex-direction:column;
gap:10px;

}


/* Messages */
.message{

padding:10px 15px;
border-radius:8px;
max-width:60%;

}

.user{

background:#212529;
color:white;
align-self:flex-end;

}

.bot{

background:#e9ecef;
align-self:flex-start;

}

.books{

background:#fff3cd;
align-self:flex-start;

}


/* Input */
.ai-input{

display:flex;
gap:10px;
padding:15px;
border-top:1px solid #ddd;
background:white;

}

.ai-input input[type="text"]{

flex:1;
padding:10px;
border-radius:6px;
border:1px solid #ccc;

}

.ai-input button{

background:#212529;
color:white;
border:none;
padding:10px 20px;
border-radius:6px;

}

</style>

<script>

const chatContainer=document.getElementById("chatContainer");
const form=document.getElementById("chatForm");
const input=document.getElementById("messageInput");
const history=document.getElementById("chatHistory");


function addMessage(text,type){

const div=document.createElement("div");

div.className="message "+type;

div.innerText=text;

chatContainer.appendChild(div);

chatContainer.scrollTop=chatContainer.scrollHeight;

}


function addHistory(text){

const div=document.createElement("div");

div.innerText=text;

history.appendChild(div);

}


function newChat(){

chatContainer.innerHTML="";

}


form.addEventListener("submit",async function(e){

e.preventDefault();

const formData=new FormData(form);

const message=formData.get("message");

addMessage(message,"user");

addHistory(message);

input.value="";

addMessage("Typing...","bot");

const res=await fetch("/ai-chat",{

method:"POST",
body:formData

});

const data=await res.json();

chatContainer.lastChild.remove();

addMessage(data.answer,"bot");


if(data.books){

let text="Recommended Books:\n\n";

data.books.forEach(b=>{

text+=b.title+" by "+b.author+"\n";

});

addMessage(text,"books");

}

});

</script>
