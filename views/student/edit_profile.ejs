<div style="position: relative; top: 150px; left: 180px; width: 900px; height: 500px;  " class="form-card">
    <form class="row g-3" method="post" action="/student/profile/edit/submit3/<%= profile._id %>">
      <h1>update details: </h1>
      <div class="col-md-12">
    <label for="inputfist" class="form-label">Enter email:</label>
    <input type="text" class="form-control" id="inputfist" name="email" placeholder="<%= profile.email %>">
  </div>
        <div class="col-md-6">
    <label for="inputfist" class="form-label">first name:</label>
    <input type="text" class="form-control" id="inputfist" name="firstName" placeholder="<%= profile.firstName %>">
  </div>
  <div class="col-md-6">
    <label for="inputlast" class="form-label">Last name:</label>
    <input type="text" class="form-control" id="inputlast" name="lastName" placeholder="<%= profile.lastName %>">
  </div>
  <div class="col-md-6">
    <label for="inputEmail4" class="form-label">Reg number:</label>
    <input type="text" class="form-control" id="inputEmail4" name="regNumber"   placeholder="<%= profile.regNumber %>">
  </div>
  <div class="col-md-6">
    <label for="inputPassword4" class="form-label">course:</label>
    <input type="text" class="form-control" id="inputPassword4" name="course" placeholder="<%= profile.course %>">
  </div>
  <div class="col-md-6">
    <label for="inputYear" class="form-label">Year</label>
    <select id="inputYear" class="form-select" name="year"  aria-placeholder="<%= profile.year %>">
      <option selected>Choose...</option>
      <option>1</option>
      <option>2</option>
      <option>3</option>
      <option>4</option>
    </select>
  </div>
  <div class="col-md-6">
    <label for="inputState" class="form-label">Semester</label>
    <select id="inputState" class="form-select" name="semester" aria-placeholder="<%= profile.semester %>">
      <option selected>Choose...</option>
        <option>1</option>
        <option>2</option>
        <option>3</option>
        <option>4</option>
        <option>5</option>
        <option>6</option>
        <option>7</option>
        <option>8</option>
    </select>
  </div>
  <div class="col-12">
    <button type="submit" class="btn btn-primary" style="position: relative; left: 420px;">Submit</button>
  </div>
</form>
  </div>
  <style>
    /* ============================= */
/* FORM CARD (OUTER BOX)         */
/* ============================= */

.form-card {
    background: linear-gradient(135deg, #1e1e2f, #2b2b40);
    border-radius: 20px;
    padding: 35px;

    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.45);
    transition: 
        transform 0.4s ease,
        box-shadow 0.4s ease;
    color: #ffffff;
}

/* HOVER EFFECT */
.form-card:hover {
    transform: translateY(-10px) scale(1.01);
    box-shadow: 0 35px 90px rgba(0, 0, 0, 0.7);
}

.footer {
    margin-top: 60px;
    position: relative;
    z-index: 1;
}

  </style>